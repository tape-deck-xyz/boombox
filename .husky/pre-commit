# Format staged files with deno fmt
.husky/run-on-staged.sh "deno fmt" "ts,tsx,js,jsx,json,jsonc,md,markdown"

# Lint staged files with deno lint (only TypeScript/JavaScript files)
.husky/run-on-staged.sh "deno lint --fix" "ts,tsx,js,jsx"

# Format check (must pass; mirrors CI lint job)
deno fmt --check

# Lint whole tree (must pass; mirrors CircleCI `deno lint`; catches files not in staged subset)
deno lint